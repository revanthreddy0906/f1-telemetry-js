{
  "name": "f1-telemetry-js",
  "version": "2.0.0",
  "description": "Reusable React + TypeScript telemetry visualization components for Formula 1 data.",
  "author": "Revanth Reddy (https://github.com/revanthreddy0906)",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/revanthreddy0906/f1-telemetry-js.git"
  },
  "homepage": "https://github.com/revanthreddy0906/f1-telemetry-js#readme",
  "bugs": {
    "url": "https://github.com/revanthreddy0906/f1-telemetry-js/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "workspaces": [
    "packages/*"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    },
    "./performance": {
      "types": "./dist/performance.d.ts",
      "import": "./dist/performance.js",
      "require": "./dist/performance.cjs"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.js",
      "require": "./dist/adapters.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./extensions": {
      "types": "./dist/extensions.d.ts",
      "import": "./dist/extensions.js",
      "require": "./dist/extensions.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:wrappers": "npm run build --workspaces --if-present",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "lint:wrappers": "npm run lint --workspaces --if-present",
    "test": "vitest",
    "test:run": "vitest run",
    "benchmark": "npm run build && node scripts/perf-benchmark.mjs",
    "benchmark:ci": "node scripts/perf-benchmark.mjs --ci",
    "benchmark:update-baseline": "node scripts/perf-benchmark.mjs --update-baseline",
    "smoke:release": "node scripts/release-smoke.mjs",
    "codemod:v2-imports": "node scripts/codemods/v2-imports.mjs",
    "api:check": "node scripts/check-api-diff.mjs",
    "api:update": "node scripts/check-api-diff.mjs --update",
    "semver:changeset": "node scripts/check-changeset.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm publish --access public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "chart.js": "^4.4.3",
    "react-chartjs-2": "^5.2.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/addon-interactions": "8.6.18",
    "@storybook/react-vite": "8.6.18",
    "@storybook/test": "8.6.18",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^2.0.5",
    "jsdom": "^24.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "8.6.18",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "keywords": [
    "formula1",
    "f1",
    "telemetry",
    "react",
    "typescript",
    "chartjs"
  ]
}
